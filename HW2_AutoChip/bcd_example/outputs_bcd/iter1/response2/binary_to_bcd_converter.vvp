S_0x5b1bab755de0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x5b1bab755f70 .scope module, "tb" "tb" 3 1;
 .timescale 0 0;
v0x5b1bab76c4c0_0 .net "bcd_output", 7 0, v0x5b1bab72b7e0_0;  1 drivers
