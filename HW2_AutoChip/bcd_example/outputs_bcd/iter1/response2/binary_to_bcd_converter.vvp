v0x5b1bab76ca40_0 .var "temp_tens", 3 0;
S_0x5b1bab719cf0 .scope module, "uut" "binary_to_bcd_converter" 3 9, 4 1 0, S_0x5b1bab755f70;
 .timescale 0 0;
    .port_info 0 /INPUT 5 "binary_input";
    .port_info 1 /OUTPUT 8 "bcd_output";
v0x5b1bab72b7e0_0 .var "bcd_output", 7 0;
v0x5b1bab72bbd0_0 .var "bcd_temp", 7 0;
v0x5b1bab76c2c0_0 .net "binary_input", 4 0, v0x5b1bab76c5b0_0;  1 drivers
v0x5b1bab76c380_0 .var/i "i", 31 0;
E_0x5b1bab753140 .event edge, v0x5b1bab76c2c0_0;
    .scope S_0x5b1bab719cf0;
T_0 ;
    %wait E_0x5b1bab753140;
    %pushi/vec4 0, 0, 8;
    %store/vec4 v0x5b1bab72bbd0_0, 0, 8;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5b1bab76c380_0, 0, 32;
T_0.0 ;
    %load/vec4 v0x5b1bab76c380_0;
    %cmpi/s 5, 0, 32;
    %jmp/0xz T_0.1, 5;
    %load/vec4 v0x5b1bab72bbd0_0;
    %parti/s 7, 0, 2;
    %load/vec4 v0x5b1bab76c2c0_0;
    %pushi/vec4 4, 0, 32;
    %load/vec4 v0x5b1bab76c380_0;
    %sub;
    %part/s 1;
    %concat/vec4; draw_concat_vec4
    %store/vec4 v0x5b1bab72bbd0_0, 0, 8;
    %load/vec4 v0x5b1bab72bbd0_0;
    %parti/s 4, 0, 2;
    %pad/u 32;
    %cmpi/u 5, 0, 32;
    %flag_inv 5; GE is !LT
    %jmp/0xz  T_0.2, 5;
    %load/vec4 v0x5b1bab72bbd0_0;
    %parti/s 4, 0, 2;
    %addi 3, 0, 4;
    %ix/load 4, 0, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x5b1bab72bbd0_0, 4, 4;
T_0.2 ;
    %load/vec4 v0x5b1bab72bbd0_0;
    %parti/s 4, 4, 4;
    %pad/u 32;
    %cmpi/u 5, 0, 32;
    %flag_inv 5; GE is !LT
    %jmp/0xz  T_0.4, 5;
    %load/vec4 v0x5b1bab72bbd0_0;
    %parti/s 4, 4, 4;
    %addi 3, 0, 4;
    %ix/load 4, 4, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x5b1bab72bbd0_0, 4, 4;
T_0.4 ;
    %load/vec4 v0x5b1bab76c380_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5b1bab76c380_0, 0, 32;
    %jmp T_0.0;
T_0.1 ;
    %load/vec4 v0x5b1bab72bbd0_0;
    %store/vec4 v0x5b1bab72b7e0_0, 0, 8;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x5b1bab755f70;
T_1 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5b1bab76c680_0, 0, 32;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5b1bab76c830_0, 0, 32;
T_1.0 ;
    %load/vec4 v0x5b1bab76c830_0;
    %cmpi/s 32, 0, 32;
    %jmp/0xz T_1.1, 5;
    %load/vec4 v0x5b1bab76c830_0;
    %pad/s 5;
    %store/vec4 v0x5b1bab76c5b0_0, 0, 5;
    %delay 10, 0;
    %load/vec4 v0x5b1bab76c830_0;
    %pushi/vec4 10, 0, 32;
    %div/s;
    %pad/s 4;
    %store/vec4 v0x5b1bab76ca40_0, 0, 4;
    %load/vec4 v0x5b1bab76c830_0;
    %pushi/vec4 10, 0, 32;
    %mod/s;
    %pad/s 4;
    %store/vec4 v0x5b1bab76c960_0, 0, 4;
    %load/vec4 v0x5b1bab76ca40_0;
    %load/vec4 v0x5b1bab76c960_0;
    %concat/vec4; draw_concat_vec4
    %store/vec4 v0x5b1bab76c750_0, 0, 8;
    %load/vec4 v0x5b1bab76c4c0_0;
    %load/vec4 v0x5b1bab76c750_0;
    %cmp/ne;
    %jmp/0xz  T_1.2, 6;
    %vpi_call/w 3 25 "$display", "Error: input %d, expected %h, got %h", v0x5b1bab76c830_0, v0x5b1bab76c750_0, v0x5b1bab76c4c0_0 {0 0 0};
    %load/vec4 v0x5b1bab76c680_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5b1bab76c680_0, 0, 32;
T_1.2 ;
    %load/vec4 v0x5b1bab76c830_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5b1bab76c830_0, 0, 32;
    %jmp T_1.0;
T_1.1 ;
    %vpi_call/w 3 29 "$display", "Mismatches: %d in 32 samples", v0x5b1bab76c680_0 {0 0 0};
