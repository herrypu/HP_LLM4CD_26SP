#! /usr/bin/vvp
:ivl_version "11.0 (stable)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision + 0;
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/system.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_sys.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/vhdl_textio.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x55ed80d00060 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x55ed80d001f0 .scope module, "tb" "tb" 3 1;
 .timescale 0 0;
v0x55ed80d15aa0_0 .net "bcd_output", 7 0, v0x55ed80cd7bd0_0;  1 drivers
v0x55ed80d15b60_0 .var "binary_input", 4 0;
v0x55ed80d15c30_0 .var/i "errors", 31 0;
v0x55ed80d15d00_0 .var "expected_bcd", 7 0;
v0x55ed80d15de0_0 .var/i "i", 31 0;
v0x55ed80d15f10_0 .var "temp_ones", 3 0;
v0x55ed80d15ff0_0 .var "temp_tens", 3 0;
S_0x55ed80cc5cf0 .scope module, "uut" "binary_to_bcd_converter" 3 9, 4 1 0, S_0x55ed80d001f0;
 .timescale 0 0;
    .port_info 0 /INPUT 5 "binary_input";
    .port_info 1 /OUTPUT 8 "bcd_output";
v0x55ed80cd7bd0_0 .var "bcd_output", 7 0;
v0x55ed80d15960_0 .net "binary_input", 4 0, v0x55ed80d15b60_0;  1 drivers
E_0x55ed80cc6390 .event edge, v0x55ed80d15960_0, v0x55ed80cd77e0_0;
S_0x55ed80cc5ed0 .scope begin, "$unm_blk_1" "$unm_blk_1" 4 6, 4 6 0, S_0x55ed80cc5cf0;
 .timescale 0 0;
v0x55ed80cd77e0_0 .var/i "decimal_value", 31 0;
    .scope S_0x55ed80cc5cf0;
T_0 ;
    %wait E_0x55ed80cc6390;
    %fork t_1, S_0x55ed80cc5ed0;
    %jmp t_0;
    .scope S_0x55ed80cc5ed0;
t_1 ;
    %load/vec4 v0x55ed80d15960_0;
    %pad/u 32;
    %store/vec4 v0x55ed80cd77e0_0, 0, 32;
    %load/vec4 v0x55ed80cd77e0_0;
    %pushi/vec4 10, 0, 32;
    %mod/s;
    %pad/s 4;
    %ix/load 4, 0, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x55ed80cd7bd0_0, 4, 4;
    %load/vec4 v0x55ed80cd77e0_0;
    %pushi/vec4 10, 0, 32;
    %div/s;
    %pad/s 4;
    %ix/load 4, 4, 0;
    %flag_set/imm 4, 0;
    %store/vec4 v0x55ed80cd7bd0_0, 4, 4;
    %end;
    .scope S_0x55ed80cc5cf0;
t_0 %join;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x55ed80d001f0;
T_1 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x55ed80d15c30_0, 0, 32;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x55ed80d15de0_0, 0, 32;
T_1.0 ;
    %load/vec4 v0x55ed80d15de0_0;
    %cmpi/s 32, 0, 32;
    %jmp/0xz T_1.1, 5;
    %load/vec4 v0x55ed80d15de0_0;
    %pad/s 5;
    %store/vec4 v0x55ed80d15b60_0, 0, 5;
    %delay 10, 0;
    %load/vec4 v0x55ed80d15de0_0;
    %pushi/vec4 10, 0, 32;
    %div/s;
    %pad/s 4;
    %store/vec4 v0x55ed80d15ff0_0, 0, 4;
    %load/vec4 v0x55ed80d15de0_0;
    %pushi/vec4 10, 0, 32;
    %mod/s;
    %pad/s 4;
    %store/vec4 v0x55ed80d15f10_0, 0, 4;
    %load/vec4 v0x55ed80d15ff0_0;
    %load/vec4 v0x55ed80d15f10_0;
    %concat/vec4; draw_concat_vec4
    %store/vec4 v0x55ed80d15d00_0, 0, 8;
    %load/vec4 v0x55ed80d15aa0_0;
    %load/vec4 v0x55ed80d15d00_0;
    %cmp/ne;
    %jmp/0xz  T_1.2, 6;
    %vpi_call/w 3 25 "$display", "Error: input %d, expected %h, got %h", v0x55ed80d15de0_0, v0x55ed80d15d00_0, v0x55ed80d15aa0_0 {0 0 0};
    %load/vec4 v0x55ed80d15c30_0;
    %addi 1, 0, 32;
    %store/vec4 v0x55ed80d15c30_0, 0, 32;
T_1.2 ;
    %load/vec4 v0x55ed80d15de0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x55ed80d15de0_0, 0, 32;
    %jmp T_1.0;
T_1.1 ;
    %vpi_call/w 3 29 "$display", "Mismatches: %d in 32 samples", v0x55ed80d15c30_0 {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 5;
    "N/A";
    "<interactive>";
    "-";
    "testbench.v";
    "outputs_bcd/iter0/response1/binary_to_bcd_converter.sv";
