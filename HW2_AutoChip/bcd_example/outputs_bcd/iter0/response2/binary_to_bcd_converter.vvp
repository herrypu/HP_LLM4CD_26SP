:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2009.vpi";
S_0x55dd9d9633a0 .scope package, "$unit" "$unit" 2 1;
 .timescale 0 0;
S_0x55dd9d963530 .scope module, "tb" "tb" 3 1;
 .timescale 0 0;
v0x55dd9d979280_0 .net "bcd_output", 7 0, v0x55dd9d979040_0;  1 drivers
v0x55dd9d979340_0 .var "binary_input", 4 0;
v0x55dd9d979410_0 .var/i "errors", 31 0;
v0x55dd9d9794e0_0 .var "expected_bcd", 7 0;
v0x55dd9d9795c0_0 .var/i "i", 31 0;
v0x55dd9d9796f0_0 .var "temp_ones", 3 0;
v0x55dd9d9797d0_0 .var "temp_tens", 3 0;
S_0x55dd9d928cf0 .scope module, "uut" "binary_to_bcd_converter" 3 9, 4 1 0, S_0x55dd9d963530;
 .timescale 0 0;
    .port_info 0 /INPUT 5 "binary_input";
    .port_info 1 /OUTPUT 8 "bcd_output";
v0x55dd9d979040_0 .var "bcd_output", 7 0;
v0x55dd9d979140_0 .net "binary_input", 4 0, v0x55dd9d979340_0;  1 drivers
E_0x55dd9d929390 .event edge, v0x55dd9d979140_0, v0x55dd9d93abd0_0, v0x55dd9d93a7e0_0;
S_0x55dd9d928ed0 .scope begin, "$unm_blk_1" "$unm_blk_1" 4 6, 4 6 0, S_0x55dd9d928cf0;
 .timescale 0 0;
v0x55dd9d93a7e0_0 .var/i "ones", 31 0;
v0x55dd9d93abd0_0 .var/i "tens", 31 0;
    .scope S_0x55dd9d928cf0;
T_0 ;
    %wait E_0x55dd9d929390;
    %fork t_1, S_0x55dd9d928ed0;
    %jmp t_0;
    .scope S_0x55dd9d928ed0;
t_1 ;
    %load/vec4 v0x55dd9d979140_0;
    %pad/u 32;
    %pushi/vec4 10, 0, 32;
    %div;
    %store/vec4 v0x55dd9d93abd0_0, 0, 32;
    %load/vec4 v0x55dd9d979140_0;
    %pad/u 32;
    %pushi/vec4 10, 0, 32;
    %mod;
    %store/vec4 v0x55dd9d93a7e0_0, 0, 32;
    %load/vec4 v0x55dd9d93abd0_0;
    %parti/s 4, 0, 2;
    %load/vec4 v0x55dd9d93a7e0_0;
    %parti/s 4, 0, 2;
    %concat/vec4; draw_concat_vec4
    %store/vec4 v0x55dd9d979040_0, 0, 8;
    %end;
    .scope S_0x55dd9d928cf0;
t_0 %join;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_0x55dd9d963530;
T_1 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x55dd9d979410_0, 0, 32;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x55dd9d9795c0_0, 0, 32;
T_1.0 ;
    %load/vec4 v0x55dd9d9795c0_0;
    %cmpi/s 32, 0, 32;
    %jmp/0xz T_1.1, 5;
    %load/vec4 v0x55dd9d9795c0_0;
    %pad/s 5;
    %store/vec4 v0x55dd9d979340_0, 0, 5;
    %delay 10, 0;
    %load/vec4 v0x55dd9d9795c0_0;
    %pushi/vec4 10, 0, 32;
    %div/s;
    %pad/s 4;
    %store/vec4 v0x55dd9d9797d0_0, 0, 4;
    %load/vec4 v0x55dd9d9795c0_0;
    %pushi/vec4 10, 0, 32;
    %mod/s;
    %pad/s 4;
    %store/vec4 v0x55dd9d9796f0_0, 0, 4;
    %load/vec4 v0x55dd9d9797d0_0;
    %load/vec4 v0x55dd9d9796f0_0;
    %concat/vec4; draw_concat_vec4
    %store/vec4 v0x55dd9d9794e0_0, 0, 8;
    %load/vec4 v0x55dd9d979280_0;
    %load/vec4 v0x55dd9d9794e0_0;
    %cmp/ne;
    %jmp/0xz  T_1.2, 6;
    %vpi_call/w 3 25 "$display", "Error: input %d, expected %h, got %h", v0x55dd9d9795c0_0, v0x55dd9d9794e0_0, v0x55dd9d979280_0 {0 0 0};
    %load/vec4 v0x55dd9d979410_0;
    %addi 1, 0, 32;
    %store/vec4 v0x55dd9d979410_0, 0, 32;
T_1.2 ;
    %load/vec4 v0x55dd9d9795c0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x55dd9d9795c0_0, 0, 32;
    %jmp T_1.0;
T_1.1 ;
    %vpi_call/w 3 29 "$display", "Mismatches: %d in 32 samples", v0x55dd9d979410_0 {0 0 0};
    %end;
    .thread T_1;
